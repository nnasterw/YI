{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "paths": {
      "@core/*": ["../src/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "references": [{ "path": ".." }]
}
